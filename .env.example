# Primary Claw3D configuration

# Browser/client gateway URL (build-time - requires `npm run build` after changes).
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# Base public domain used to derive development origins. When set to
# `example.com`, Next.js allows `claw3d.example.com` and
# `openclaw.example.com` during development.
WEB_SERVER_DOMAIN=example.com
# Optional direct override/addition for Next.js allowedDevOrigins.
# Comma-separated host names; protocol is optional and stripped.
# CLAW3D_ALLOWED_DEV_ORIGINS=claw3d.example.com,openclaw.example.com

# Debug UI.
DEBUG=true

# App server.
PORT=3000
HOST=127.0.0.1

# Runtime gateway defaults - take effect on server restart without a rebuild.
# Use these instead of NEXT_PUBLIC_GATEWAY_URL when you want to change the
# gateway endpoint without re-running `npm run build`.
CLAW3D_GATEWAY_URL=ws://localhost:18789
CLAW3D_GATEWAY_TOKEN=
# Tell Studio which backend the runtime gateway URL represents.
# Valid values: openclaw, hermes, demo, custom.
CLAW3D_GATEWAY_ADAPTER_TYPE=openclaw

# Restricts which upstream gateway hosts Studio may proxy to.
UPSTREAM_ALLOWLIST=localhost,<ServerDomain>,<OtherAllowedDomains>

# Required when binding Studio to a public or remote host.
STUDIO_ACCESS_TOKEN=

# Optional: make the Studio server authenticate upstream as one persistent
# OpenClaw device so multiple browsers can use the same Claw3D deployment.
# CLAW3D_GATEWAY_AUTH_MODE=server-device

# Optional OpenClaw gateway-host operations
# Advanced only: some gateway-host operations can still use SSH, but marketplace skill install does not require it.
# OPENCLAW_GATEWAY_SSH_TARGET=
# OPENCLAW_GATEWAY_SSH_USER=
# OPENCLAW_GATEWAY_SSH_PORT=
# OPENCLAW_GATEWAY_SSH_STRICT_HOST_KEY_CHECKING=accept-new

# Optional Hermes Agent adapter
# Run `npm run hermes-adapter` to start the adapter, then connect Claw3D to ws://localhost:18789.
# HERMES_API_URL=http://localhost:8642
# HERMES_API_KEY=
# HERMES_ADAPTER_PORT=18789
# HERMES_MODEL=hermes
# HERMES_AGENT_NAME=Hermes
# If CLAW3D_GATEWAY_URL is unset, Studio can still detect this local adapter port.

# Optional voice features
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
